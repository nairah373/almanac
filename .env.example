# ──────────────────────────────────────────────────────────────
# Almanac — environment variables. Copy to `.env` and fill in.
# See SETUP.md for step-by-step instructions to obtain each value.
# ──────────────────────────────────────────────────────────────

# ─── Supabase (Project Settings → API) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database — Supabase Postgres (Project Settings → Database → Connection string) ───
# DATABASE_URL uses the pooled connection (port 6543) for the app.
# DIRECT_URL uses the direct connection (port 5432) for migrations.
DATABASE_URL=postgresql://postgres.your-project-ref:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project-ref:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# ─── Razorpay — test mode (Dashboard → Settings → API Keys) ───
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-test-secret
# Razorpay → Settings → Webhooks → the secret you set on the webhook
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Same key id, exposed to the browser for Razorpay Checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# ─── App ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
